modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 20257
externalPort = 3000

[[ports]]
localPort = 20258
externalPort = 3003

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APPLE_KEY_ID = "U8VL3PNZ5V"
APPLE_ISSUER_ID = "cda99d8c-713a-49cd-9292-47ca6e6853eb"
